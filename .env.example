# Talk to Your Data — configuration
# Copy to .env.local and adjust. NO real keys are committed to this repo.

# Which LLM backend to use: "ollama" (local, no key) or "gemini" (cloud).
LLM_PROVIDER=ollama

# --- Ollama (default; runs locally, no API key) ---
# Install from https://ollama.com, then: `ollama pull llama3.1`
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Google Gemini (optional; only used when LLM_PROVIDER=gemini) ---
# Get a key at https://aistudio.google.com/apikey  — set it in .env.local, never commit it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
